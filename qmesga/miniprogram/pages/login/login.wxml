<view class="login-page {{darkMode ? 'dark-mode' : ''}}">
  <!-- Background Decorative Blobs -->
  <view class="bg-blob blob-top"></view>
  <view class="bg-blob blob-bottom"></view>

  <!-- Main Content -->
  <view class="login-content">
    <!-- Branding -->
    <view class="brand-section">
      <view class="brand-icon">
        <view class="brand-bolt">⚡</view>
      </view>
      <text class="brand-name">VELOCITY</text>
    </view>

    <!-- Hero Text -->
    <view class="hero-section">
      <text class="hero-title">快灵感</text>
      <text class="hero-subtitle">让灵感快人一步</text>
    </view>

    <!-- Login Actions -->
    <view class="login-actions">
      <!-- Primary: WeChat Quick Login -->
      <view class="btn-wechat {{isLoggingIn ? 'btn-disabled' : ''}}" bindtap="wxQuickLogin">
        <view class="wechat-icon">💬</view>
        <text class="btn-wechat-text">{{isLoggingIn ? '登录中...' : '微信快捷登录'}}</text>
      </view>
    </view>

    <!-- Terms -->
    <view class="terms-section">
      <text class="terms-text">继续即表示同意 </text>
      <text class="terms-link">服务条款</text>
      <text class="terms-text"> 和 </text>
      <text class="terms-link">隐私政策</text>
    </view>
  </view>
</view>
