<view class="ml-page {{darkMode ? 'dark-mode' : ''}}">
  <view class="bg-blob blob-top"></view>
  <view class="bg-blob blob-right"></view>

  <view class="ml-content">
    <!-- Header -->
    <view class="ml-header">
      <text class="ml-title">欢迎回来</text>
      <text class="ml-subtitle">使用手机号码登录</text>
    </view>

    <!-- Form -->
    <view class="ml-form">
      <!-- Phone Number -->
      <view class="field-group">
        <text class="field-label">手机号</text>
        <view class="input-row">
          <view class="country-code">
            <text class="country-text">+86</text>
            <view class="code-divider"></view>
          </view>
          <input
            class="field-input"
            type="number"
            placeholder="000 0000 0000"
            placeholder-class="input-placeholder"
            bindinput="onPhoneInput"
            value="{{phone}}"
            maxlength="11"
          />
        </view>
      </view>

      <!-- Verification Code -->
      <view class="field-group">
        <view class="field-label-row">
          <text class="field-label">验证码</text>
          <view class="send-code-btn {{codeSent ? 'code-sent' : ''}}" bindtap="sendCode">
            <text class="send-code-text">{{codeSent ? countdown + 's后重发' : '发送验证码'}}</text>
          </view>
        </view>
        <view class="input-row">
          <input
            class="field-input"
            type="number"
            placeholder="请输入6位验证码"
            placeholder-class="input-placeholder"
            bindinput="onCodeInput"
            value="{{code}}"
            maxlength="6"
          />
        </view>
      </view>

      <!-- Login Button -->
      <view class="login-btn {{canLogin ? 'login-btn-active' : 'login-btn-disabled'}}" bindtap="doLogin">
        <text class="login-btn-text">登录</text>
        <text class="login-arrow">→</text>
      </view>
    </view>

    <!-- Footer -->
    <view class="ml-footer">
      <view class="secure-row">
        <view class="secure-line"></view>
        <text class="secure-text">安全通道</text>
        <view class="secure-line"></view>
      </view>
      <view class="wechat-back-btn" bindtap="goBackToWechatLogin">
        <view class="wechat-avatar">💬</view>
        <text class="wechat-back-text">返回微信登录</text>
      </view>
    </view>
  </view>
</view>
