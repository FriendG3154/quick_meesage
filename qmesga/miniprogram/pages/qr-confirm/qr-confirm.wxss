.qr-confirm-page {
  min-height: 100vh;
  background: #f9f9f9;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
}

/* Header */
.header {
  padding-top: 160rpx;
  padding-bottom: 80rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1c1917;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #78716c;
}

/* Content */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Error Section */
.error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.error-text {
  font-size: 30rpx;
  color: #b4534e;
  text-align: center;
}

/* Confirm Section */
.confirm-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 60rpx;
}

.icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.monitor-icon {
  font-size: 72rpx;
}

.confirm-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1c1917;
  margin-bottom: 24rpx;
}

.confirm-desc {
  display: block;
  font-size: 28rpx;
  color: #78716c;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 80rpx;
  padding: 0 40rpx;
}

/* Action Buttons */
.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-cancel {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #f5f3ef;
  color: #78716c;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  text-align: center;
}

.btn-cancel::after {
  border: none;
}

.btn-cancel:active {
  opacity: 0.8;
}

.btn-confirm {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #0052FF;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: none;
  text-align: center;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm:active {
  opacity: 0.88;
}

.btn-confirm[disabled] {
  opacity: 0.6;
}

/* Loading */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
