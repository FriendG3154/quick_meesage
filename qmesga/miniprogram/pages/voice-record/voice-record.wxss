.vr-page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  position: relative;
}

/* Dot grid background */
.vr-page::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: radial-gradient(circle, var(--color-dot-grid) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  pointer-events: none;
  z-index: 0;
}

/* Top Bar */
.vr-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-topbar);
  border-bottom: 1rpx solid var(--color-border-light);
}

.vr-topbar-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
}
.top-bar-title{
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.back-btn:active { opacity: 0.4; }

.back-arrow {
  font-size: 52rpx;
  color: #0052FF;
  font-weight: 300;
  line-height: 1;
}

.back-label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.header-capsule {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-capsule-bg);
  border: 1rpx solid var(--color-capsule-border);
  border-radius: 9999rpx;
  padding: 10rpx 24rpx;
  height: 56rpx;
}

.capsule-dots {
  font-size: 28rpx;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.capsule-divider {
  width: 2rpx;
  height: 28rpx;
  background: var(--color-capsule-divider);
}

.capsule-record-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-text-muted);
}

.capsule-dot-recording {
  border: none;
  background: #EF4444;
}

/* Content */
.vr-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx 280rpx;
  position: relative;
  z-index: 1;
}

/* Status */
.rec-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 64rpx;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.rec-dot-active {
  background: #EF4444;
}

.rec-dot-paused {
  background: #6B7280;
}

.rec-label {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--color-text-muted);
  letter-spacing: 0.2em;
}

/* Timer */
.timer-display {
  margin-bottom: 80rpx;
}

.timer-text {
  font-size: 176rpx;
  font-weight: 800;
  color: var(--color-text);
  letter-spacing: -0.04em;
  line-height: 1;
}

/* Waveform */
.waveform-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 200rpx;
  margin-bottom: 64rpx;
}

.waveform-bar {
  width: 12rpx;
  background: #0052FF;
  border-radius: 9999rpx;
  min-height: 16rpx;
  max-height: 180rpx;
  transition: height 0.25s ease-in-out;
}

/* Transcription Card */
.transcription-card {
  width: 100%;
  background: var(--color-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  position: relative;
}

.transcription-badge {
  position: absolute;
  top: -24rpx;
  left: 40rpx;
  background: #0052FF;
  border-radius: 9999rpx;
  padding: 8rpx 24rpx;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 0.12em;
}

.transcription-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.7;
  font-style: italic;
}

.transcription-footer {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.transcribing-indicator {
  font-size: 22rpx;
  font-weight: 700;
  color: #0052FF;
  letter-spacing: 0.05em;
}

/* Bottom Controls */
.vr-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-topbar);
  border-top: 1rpx solid var(--color-border-light);
  padding: 40rpx 64rpx 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ctrl-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.ctrl-btn:active { opacity: 0.6; }

.ctrl-btn-inner {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(229, 231, 235, 0.7);
}

.ctrl-btn-gray {
  background: var(--color-card-alt);
}

.ctrl-btn-blue {
  background: rgba(0, 82, 255, 0.06);
  border-color: rgba(0, 82, 255, 0.1);
}

.ctrl-icon {
  font-size: 40rpx;
}

.ctrl-icon-check {
  font-size: 44rpx;
  color: #0052FF;
  font-weight: 700;
}

.ctrl-label {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--color-text-muted);
  letter-spacing: 0.1em;
}

.ctrl-label-blue {
  color: #0052FF;
}

/* Main Mic Button */
.main-btn-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.main-btn-glow {
  position: absolute;
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  background: rgba(0, 82, 255, 0.2);
  filter: blur(20rpx);
}

.main-btn {
  position: relative;
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.main-btn:active {
  transform: scale(0.92);
}

.main-btn-recording {
  background: #0052FF;
}

.main-btn-idle {
  background: #0052FF;
}

.main-btn-icon {
  font-size: 64rpx;
}

.bottom-spacer {
  height: 240rpx;
}
