.stat-page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* Top Bar */
.stat-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-topbar);
}

.stat-topbar-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn:active { opacity: 0.4; }

.back-arrow {
  font-size: 52rpx;
  color: #0052FF;
  font-weight: 300;
  line-height: 1;
}

.stat-topbar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: -0.01em;
}

/* Scroll */
.stat-scroll {
  flex: 1;
  height: 100vh;
}

.stat-content {
  padding: 0 32rpx;
  padding-top: calc(88rpx + var(--status-bar-height, 44px) + 24rpx);
}

/* Week Header */
.week-header {
  padding: 24rpx 0 48rpx;
}

.week-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.week-title {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  color: var(--color-text);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

/* Metric Grid */
.metric-grid {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  flex: 1;
  border-radius: 16rpx;
  padding: 40rpx;
}

.metric-primary {
  background: var(--color-card);
  border: 2rpx solid var(--color-primary-soft);
}

.metric-secondary {
  background: var(--color-card-alt);
}

.metric-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.metric-icon-emoji {
  font-size: 40rpx;
}

.metric-badge {
  background: rgba(0, 82, 255, 0.1);
  color: #0052FF;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
}

.metric-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.metric-value {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-text);
  letter-spacing: -0.02em;
}

/* Category Card */
.category-card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 48rpx;
  margin-bottom: 40rpx;
  border: 2rpx solid var(--color-primary-soft);
}

.category-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 64rpx;
}

.category-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.category-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.active-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.active-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0052FF;
}

.active-text {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
  letter-spacing: 0.1em;
}

/* Stat Bars */
.stat-bar-item {
  margin-bottom: 64rpx;
}

.stat-bar-item:last-child {
  margin-bottom: 0;
}

.stat-bar-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.bar-label-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bar-icon {
  font-size: 32rpx;
}

.bar-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.bar-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.bar-pct {
  font-size: 20rpx;
  font-weight: 700;
  color: #6c7b6c;
  opacity: 0.6;
  margin-left: 8rpx;
}

.bar-track {
  height: 12rpx;
  background: var(--color-card-alt);
  border-radius: 9999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #0052FF;
  border-radius: 9999rpx;
}

/* Trends */
.trends-section {
  margin-bottom: 40rpx;
}

.trends-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.trend-item {
  background: var(--color-card-alt);
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.trend-item:active {
  opacity: 0.7;
}

.trend-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: var(--color-card);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trend-icon {
  font-size: 36rpx;
}

.trend-info {
  flex: 1;
}

.trend-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.trend-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.trend-arrow {
  font-size: 48rpx;
  color: rgba(0,0,0,0.2);
  line-height: 1;
}

/* Feature Banner */
.feature-banner {
  height: 280rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #0a0f2e 0%, #001070 50%, #0052FF 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.banner-overlay {
  padding: 40rpx;
}

.banner-tag {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.15em;
  margin-bottom: 12rpx;
}

.banner-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.01em;
}

.bottom-spacer {
  height: 160rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.empty-desc {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
