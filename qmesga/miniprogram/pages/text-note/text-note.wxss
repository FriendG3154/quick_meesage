.note-page {
  height: 100vh;
  background: var(--color-card);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Top Bar */
.note-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 200;
  background: var(--color-topbar);
}

.note-topbar-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
}
.top-bar-title{
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.back-btn:active { opacity: 0.4; }

.back-arrow {
  font-size: 52rpx;
  color: var(--color-text);
  font-weight: 300;
  line-height: 1;
}

.back-label {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}

.header-capsule {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-capsule-bg);
  border: 1rpx solid var(--color-capsule-border);
  border-radius: 9999rpx;
  padding: 10rpx 24rpx;
  height: 56rpx;
}

.capsule-dots {
  font-size: 28rpx;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.capsule-divider {
  width: 2rpx;
  height: 28rpx;
  background: var(--color-capsule-divider);
}

.capsule-record-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-text-muted);
}

/* Meta Bar */
.meta-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 150;
  height: 68rpx;
  background: var(--color-topbar);
  border-bottom: 1rpx solid var(--color-border-light);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.draft-badge {
  background: rgba(0, 82, 255, 0.1);
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
}

.draft-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #0052FF;
  letter-spacing: 0.08em;
}

.last-edit {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

.saved-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cloud-icon {
  font-size: 28rpx;
}

.saved-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

/* Editor Area */
.note-editor-wrap {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.dot-grid-bg {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, var(--color-dot-grid) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  opacity: 0.5;
  pointer-events: none;
}

.note-editor {
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 400rpx;
  padding: 48rpx;
  font-size: 34rpx;
  line-height: 1.7;
  color: var(--color-text);
  font-weight: 400;
  box-sizing: border-box;
}

/* Editor content styling via ql classes */
.note-editor .ql-blank::before {
  color: rgba(102, 102, 102, 0.45);
  font-weight: 400;
  font-size: 34rpx;
}

/* Markdown Toolbar */
.md-toolbar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 500;
  background: var(--color-toolbar);
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
  height: 96rpx;
}

.md-toolbar-scroll {
  width: 100%;
  height: 100%;
  white-space: nowrap;
}

.md-toolbar-inner {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 16rpx;
  gap: 4rpx;
}

.md-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.md-btn:active {
  background: rgba(0,0,0,0.06);
}

.md-btn-active {
  background: rgba(0, 82, 255, 0.12);
  border-radius: 16rpx;
}

.md-btn-active .md-icon {
  color: #0052FF;
  font-weight: 700;
}

.md-icon {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.md-bold {
  font-weight: 900;
  font-size: 36rpx;
}

.md-italic {
  font-style: italic;
  font-size: 36rpx;
}

.md-underline {
  text-decoration: underline;
  font-size: 36rpx;
}

.md-strike {
  text-decoration: line-through;
  font-size: 36rpx;
}

.md-divider {
  width: 2rpx;
  height: 40rpx;
  background: var(--color-border);
  margin: 0 8rpx;
  flex-shrink: 0;
}

/* Bottom Action Bar */
.note-actions {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 600;
  background: var(--color-topbar);
  border-top: 1rpx solid var(--color-border);
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
}

.note-char-count {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.char-label {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: rgba(75,85,99,0.5);
  text-transform: uppercase;
}

.char-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #0052FF;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.note-action-btns {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.btn-draft {
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
}

.btn-draft:active {
  background: rgba(0,0,0,0.05);
}

.btn-draft-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.btn-send {
  background: #0052FF;
  border-radius: 9999rpx;
  padding: 20rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-send:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-send-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.send-arrow {
  font-size: 28rpx;
  color: #ffffff;
}
